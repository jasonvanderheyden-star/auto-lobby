// Auto Lobby starter schema.
// Multi-tenant from day 1. Event-sourced audit trail.
// Provenance on every auto-filled field.
// See docs/Detection-Pipeline.md for the model narrative.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Tenancy
// ============================================================

/// A GR firm / law firm running the agency GTM motion: manages client
/// tenants (white-label) and/or files consultant MCRs for clients.
/// The firm's own in-house lobbying lives in a normal Tenant flagged
/// isAgencyOwnTenant. See docs/Agency-Motion-Parked.md.
model Agency {
  id         String  @id @default(cuid())
  /// Clerk Organization ID of the firm itself, when the firm signs in as an org.
  clerkOrgId String? @unique
  name       String

  // White-label defaults — cascade to client tenants unless overridden there.
  logoUrl      String?
  brandColor   String?
  productName  String?
  supportEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants     Tenant[]
  members     AgencyMember[]
  engagements Engagement[]
}

enum AgencyMemberRole {
  admin // manages clients, billing, members
  staff // prepares drafts on client tenants
  consultant // registered consultant lobbyist — certifies own consultant MCRs
}

model AgencyMember {
  id          String           @id @default(cuid())
  agencyId    String
  agency      Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  clerkUserId String
  email       String
  name        String?
  role        AgencyMemberRole @default(staff)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  engagements Engagement[] // undertakings this consultant is registrant for

  @@unique([agencyId, clerkUserId])
  @@index([clerkUserId])
}

model Tenant {
  id             String   @id @default(cuid())
  clerkOrgId     String?  @unique // Clerk Organization ID — stable join key for webhook upserts
  name           String
  industry       String?
  jurisdiction   String   @default("federal") // federal | provincial | municipal | multi
  registrationId        String?   // OCL registration ID if active
  registrationExpiresAt DateTime? // annual renewal deadline under the Lobbying Act

  /// Agency GTM (non-negotiable #7): set when this tenant is managed by a firm.
  agencyId         String?
  agency           Agency? @relation(fields: [agencyId], references: [id])
  /// True for the firm's own in-house filing tenant (use case 2c).
  isAgencyOwnTenant Boolean @default(false)

  // White-label branding hooks — nullable, always rendered through variables.
  // Fall back to agency defaults, then platform defaults.
  logoUrl      String?
  brandColor   String?
  productName  String?
  supportEmail String?

  createdAt             DateTime  @default(now())
  updatedAt      DateTime @updatedAt

  orgProfile             OrgProfile?
  employees              Employee[]
  members                TenantMember[]
  calendarConnections    CalendarConnection[]
  rawCalendarEvents      RawCalendarEvent[]
  detectedMeetings       DetectedMeeting[]
  hoursLedger            HoursLedgerEntry[]
  auditEvents            AuditEvent[]
  dpohSubjectPreferences DpohSubjectPreference[]
  engagementsAsClient    Engagement[]            @relation("EngagementClientTenant")

  @@index([agencyId])
}

enum TenantMemberRole {
  admin // manage settings, members, calendar connections
  contributor // calendar is ingested; appears as named lobbyist
  reviewer // triage drafts: confirm DPOHs, exclude, edit — cannot certify
  certifier // the Responsible Officer — the only role that can certify a batch
}

/// App-level membership + permissions inside a tenant. Distinct from
/// Employee (filing data: who is named on the registration). A person is
/// usually both, joined by email. Roles are additive — the CEO at a small
/// org is [admin, contributor, certifier].
model TenantMember {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clerkUserId String?
  email       String
  name        String?
  roles       TenantMemberRole[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([clerkUserId])
}

/// A consultant-lobbying undertaking: firm × client × registration.
/// Drives meeting→client attribution (use case 2a). The client may or may
/// not also be a managed Tenant in the platform.
model Engagement {
  id       String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  /// The registered consultant lobbyist — the registrant who certifies MCRs
  /// for this undertaking.
  consultantMemberId String?
  consultantMember   AgencyMember? @relation(fields: [consultantMemberId], references: [id])

  clientName     String
  /// Set when the client is also a managed tenant on the platform.
  clientTenantId String?
  clientTenant   Tenant? @relation("EngagementClientTenant", fields: [clientTenantId], references: [id])

  /// OCL consultant registration number for this undertaking, once registered.
  registrationNum String?

  // Attribution signals for the auto-suggest engine — all explainable.
  clientDomains    String[] // attendee email domains that indicate this client
  subjectKeywords  String[] // title/description keywords
  subjects         String[] // OCL subject-matter codes from the registration
  keyInstitutions  String[] // institution IDs routinely engaged for this client

  status         String    @default("active") // active | ended
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  detectedMeetings DetectedMeeting[]

  @@index([agencyId])
  @@index([clientTenantId])
}

/// The seed crystal for all pre-fill logic. Set once at onboarding,
/// refined over time from user overrides.
model OrgProfile {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultSubjects    String[] // subject-matter IDs used as priors
  keyInstitutions    String[] // institution IDs routinely engaged
  prepTimeMultiplier Float    @default(0) // 0 = don't auto-count; e.g. 0.25 = 25% prep
  calendarBodyOptIn  Boolean  @default(false)
  notesConnectors    Json? // { granola: true, otter: false, zoomAi: true, ... }
  filingVoice        String? // learned sample of this org's MCR description style
  updatedAt          DateTime @updatedAt
}

model Employee {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String
  role         String?
  isLobbyist   Boolean  @default(true) // named on registration
  isRegistrant Boolean  @default(false) // senior officer who certifies
  createdAt    DateTime @default(now())

  @@unique([tenantId, email])
}

// ============================================================
// Calendar ingestion
// ============================================================

enum CalendarProvider {
  google
  microsoft365
}

enum CalendarConnectionStatus {
  active
  disconnected
  token_refresh_failed
}

model CalendarConnection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Clerk userId of the person who connected this calendar.
  connectedByUserId String

  provider          CalendarProvider @default(google)
  /// Stable provider-side account identifier (Google 'sub' claim). Immutable per account.
  externalAccountId String
  /// Email address of the connected calendar owner — display only, not a join key.
  email             String

  /// Base64 of (iv ‖ authTag ‖ ciphertext) from AES-256-GCM. See src/server/crypto/tokens.ts.
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  accessTokenExpiresAt  DateTime
  /// Scopes granted by the user (may be a subset of requested).
  scopes                String[]

  status       CalendarConnectionStatus @default(active)
  /// Short machine-readable reason when status != active.
  statusReason String?

  /// Google syncToken for incremental fetch. Null until first sync completes.
  syncToken    String?
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events RawCalendarEvent[]

  @@unique([tenantId, provider, externalAccountId])
  @@index([tenantId])
  @@index([status])
}

model RawCalendarEvent {
  id           String             @id @default(cuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectionId String
  connection   CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  /// Provider's event ID — stable per calendar.
  externalId String
  /// iCalendar UID — stable across calendars for the same meeting. Used to dedupe when multiple attendees' calendars are connected.
  icalUID    String?

  title          String?
  startsAt       DateTime?
  endsAt         DateTime?
  organizerEmail String?
  /// [{ email, displayName, responseStatus, organizer, optional }]
  attendees      Json
  location       String?
  /// "default" | "public" | "private" | "confidential"
  visibility     String?
  /// "confirmed" | "tentative" | "cancelled"
  eventStatus    String?

  /// Whether the description field was ingested. Default off per CLAUDE.md; opt-in per tenant.
  descriptionIncluded Boolean @default(false)
  description         String?

  /// Full provider response for audit / replay.
  rawPayload Json
  etag       String?

  ingestedAt DateTime @default(now())

  detectedMeeting DetectedMeeting?

  @@unique([connectionId, externalId])
  @@index([tenantId, startsAt])
  @@index([connectionId])
}

// ============================================================
// Institution + DPOH registries (proprietary moat)
// ============================================================

model InstitutionRegistry {
  id           String   @id @default(cuid())
  name         String   @unique
  acronym      String?
  jurisdiction String // federal | provincial | municipal
  domains      String[] // email domains that map to this institution
  isDpohSource Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  officials        PublicOfficial[]
  detectedMeetings DetectedMeeting[]

  @@index([domains])
}

model PublicOfficial {
  id             String              @id @default(cuid())
  name           String
  email          String?
  role           String
  institutionId  String
  institution    InstitutionRegistry @relation(fields: [institutionId], references: [id])
  isDpoh         Boolean
  dpohBasis      String? // role | position-designation | office-designation
  ruleRef        String? // e.g. "Lobbying Act s. 2(1) 'DPOH' (c)(i)"
  resolvedFrom   String // ocl-comm-reports | manual-ministers | parliament | geds | tbs-exempt
  confidence     Float
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  createdAt      DateTime            @default(now())

  subjectPreferences DpohSubjectPreference[]

  @@index([email])
  @@index([institutionId])
}

// ============================================================
// Detection + classification
// ============================================================

model DetectedMeeting {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rawEventId               String           @unique
  rawEvent                 RawCalendarEvent @relation(fields: [rawEventId], references: [id])
  title                    String
  startAt                  DateTime
  endAt                    DateTime
  employeeEmail            String
  institutionId            String?
  institution              InstitutionRegistry? @relation(fields: [institutionId], references: [id])
  hadDpoh                  Boolean          @default(false)
  classification           String // lobbying | not-lobbying | needs-info
  classificationConfidence Float
  status                   String           @default("auto-drafted") // auto-drafted | ceo-certified | submitted | excluded | needs-info

  // Consultant client attribution (use case 2a). Suggested by the engine
  // with provenance; only a confirmed attribution feeds a filing batch.
  engagementId         String?
  engagement           Engagement? @relation(fields: [engagementId], references: [id])
  /// auto-suggested | confirmed | manual — auto-suggested rows are never
  /// batched into an MCR until a consultant confirms (anti-over-reporting).
  engagementSource     String?
  engagementConfidence Float?

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  attendees   MeetingAttendee[]
  reasons     ClassificationReason[]
  draftMcr    DraftMcr?
  hoursLedger HoursLedgerEntry[]

  @@index([tenantId, startAt])
  @@index([tenantId, classification])
}

model MeetingAttendee {
  id                 String          @id @default(cuid())
  meetingId          String
  meeting            DetectedMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name               String
  email              String
  resolvedOfficialId String? // FK to PublicOfficial when resolved
  isInternal         Boolean         @default(false)
  isDpoh             Boolean?

  @@index([meetingId])
}

/// One row per rule/signal that drove a classification verdict.
/// Feeds the "why we classified this" explainer in the UI.
model ClassificationReason {
  id        String          @id @default(cuid())
  meetingId String
  meeting   DetectedMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  ok        Boolean? // true = supports verdict, false = refutes, null = neutral/info
  text      String
  citation  String? // e.g. "Lobbying Act s. 5(3)"
  weight    Float           @default(1.0)
}

// ============================================================
// Filings (MCRs)
// ============================================================

model DraftMcr {
  id                String          @id @default(cuid())
  meetingId         String          @unique
  meeting           DetectedMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  // Public MCR structured fields (what actually goes to OCL)
  subjects          Json // [{ subjectId, source }]
  institutionId     String?
  namedLobbyists    Json // [{ employeeId, name }]
  // Internal narrative (never filed, for audit trail only)
  description       String?
  descriptionSource String? // level-0 | level-1 | level-2 | level-3 | level-4 | manual
  // Full field-level provenance snapshot at time of draft
  provenance        Json // { field: { value, source, confidence } }

  // Certification routing (use case 2b): agency staff prepare the draft,
  // then route it to the client's Responsible Officer to certify.
  // Never bypasses non-negotiable #1 — the RO always clicks Certify themselves.
  routedForCertificationAt DateTime?
  routedToEmail            String?
  /// SHA-256 hash of the single-use routing token emailed to the RO. Raw token never stored.
  routingTokenHash         String?
  routingTokenExpiresAt    DateTime?
  routedByUserId           String? // Clerk userId of the agency staffer who routed

  certifiedAt       DateTime?
  certifiedById     String? // Employee id of the senior officer
  certifiedByUserId String? // Clerk userId of the certifier, when authenticated in-app
  submittedAt       DateTime?
  lrsReceiptId      String?
  lrsScreenshot     String? // evidence URL
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([routingTokenHash])
}

// ============================================================
// DPOH subject-matter learning loop
// ============================================================

model DpohSubjectPreference {
  id               String   @id @default(cuid())
  tenantId         String
  publicOfficialId String
  oclCodes         String[] // OCL canonical codes stored as strings, e.g. ["41","11","13"]
  lastConfirmedAt  DateTime @updatedAt
  confirmedBy      String   // userId

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  publicOfficial PublicOfficial @relation(fields: [publicOfficialId], references: [id])

  @@unique([tenantId, publicOfficialId])
  @@index([tenantId])
}

// ============================================================
// Hours accounting — two separate buckets
// ============================================================

model HoursLedgerEntry {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meetingId     String
  meeting       DetectedMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  employeeEmail String
  bucket        String // threshold-clock | mcr-reportable
  minutes       Int
  kind          String          @default("meeting") // meeting | prep | grassroots
  recordedAt    DateTime        @default(now())

  @@index([tenantId, bucket, recordedAt])
  @@index([tenantId, employeeEmail, recordedAt])
}

// ============================================================
// Audit trail — append-only, never mutate
// ============================================================

model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor     String // user email or "system"
  actorRole          String?   // "registrant" | "lobbyist" | "agency-admin" | "system"
  onBehalfOfTenantId String?   // set when an agency actor acts for a client tenant
  action    String // detected | classified | drafted | overridden | certified | submitted | acknowledged
  subject   String // entity id affected
  payload   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, subject])
}

// ============================================================
// OCL open-data mirror (read-only reference)
// Loaded from https://open.canada.ca CSV dumps.
// ============================================================

model OclPublicRegistration {
  id              String    @id
  registrationNum String
  companyName     String
  registrantName  String?
  subjects        String[]
  institutions    String[]
  status          String
  effectiveDate   DateTime?
  rawPayload      Json
  ingestedAt      DateTime  @default(now())

  @@index([companyName])
  @@index([registrationNum])
}

model OclPublicCommReport {
  id                String   @id
  registrationId    String
  communicationDate DateTime
  institution       String
  dpohName          String
  dpohTitle         String?
  subjects          String[]
  rawPayload        Json
  ingestedAt        DateTime @default(now())

  @@index([registrationId])
  @@index([communicationDate])
  @@index([dpohName])
}
