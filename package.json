{
  "name": "auto-lobby",
  "version": "0.1.0",
  "private": true,
  "description": "Automated Canadian lobbyist compliance. Deep Sky is the first user.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e .env.local -- prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "prisma db seed",
    "ocl:import": "dotenv -e .env.local -- tsx scripts/import-ocl.ts",
    "tenants:backfill": "dotenv -e .env.local -- tsx scripts/backfill-tenants.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "dotenv -e .env.local -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.3",
    "@prisma/client": "^6.19.3",
    "iconv-lite": "^0.7.2",
    "next": "^15.3.1",
    "papaparse": "^5.5.3",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "svix": "^1.91.1",
    "unzipper": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.5",
    "@types/node": "^22.15.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@types/unzipper": "^0.10.11",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.1",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
